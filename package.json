{
  "name": "@mendypp/paperclip-plugin-chat",
  "version": "0.1.1",
  "description": "Multi-adapter AI chat plugin for Paperclip — supports Claude, Codex, and OpenCode",
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "paperclipPlugin": {
    "manifest": "./dist/manifest.js",
